<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stepstone Brand Guardian</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&display=swap');

  :root {
    --brand-blue: #1a1f6e;
    --coral: #f07060;
    --turquoise: #40c8c8;
    --light-bg: #f5f6fa;
    --mid-grey: #e8e9f0;
    --text-secondary: #6b7280;
    --pass: #10b981;
    --at-risk: #f59e0b;
    --fail: #ef4444;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--light-bg);
    color: var(--brand-blue);
    min-height: 100vh;
  }

  /* HEADER */
  header {
    background: #ffffff;
    padding: 0 40px;
    height: 84px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1.5px solid var(--mid-grey);
    box-shadow: 0 1px 4px rgba(26,31,110,0.06);
  }

  .logo-wrap {
    display: flex;
    align-items: center;
    max-width: 340px;
    overflow: hidden;
  }

  .logo-wrap svg {
    max-height: 66px;
    width: auto;
    display: block;
  }

  .badge {
    background: rgba(26,31,110,0.07);
    color: var(--brand-blue);
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 20px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  /* GRADIENT BAR */
  .gradient-bar {
    height: 5px;
    background: linear-gradient(90deg, #FF9E8C 0%, #F0F0E7 50%, #29D3DF 100%);
  }

  /* MAIN LAYOUT */
  .main {
    max-width: 860px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .page-title {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--turquoise);
    margin-bottom: 10px;
  }

  .page-heading {
    font-size: 36px;
    font-weight: 800;
    color: var(--brand-blue);
    line-height: 1.1;
    margin-bottom: 8px;
    letter-spacing: -0.5px;
  }

  .page-sub {
    font-size: 16px;
    color: var(--text-secondary);
    font-weight: 400;
    margin-bottom: 40px;
    line-height: 1.5;
  }

  /* UPLOAD ZONE */
  .upload-zone {
    border: 2px dashed var(--mid-grey);
    border-radius: 16px;
    padding: 40px 32px;
    text-align: center;
    background: white;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
    margin-bottom: 20px;
  }

  .upload-zone:hover, .upload-zone.dragover {
    border-color: var(--turquoise);
    background: #f0fbfb;
  }

  .upload-zone input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .upload-icon {
    width: 48px;
    height: 48px;
    margin: 0 auto 16px;
  }

  .upload-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--brand-blue);
    margin-bottom: 6px;
  }

  .upload-hint {
    font-size: 13px;
    color: var(--text-secondary);
  }

  .upload-hint strong { color: var(--turquoise); }

  /* PREVIEW */
  .preview-strip {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .preview-item {
    position: relative;
    width: 80px;
    height: 80px;
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid var(--mid-grey);
    background: var(--light-bg);
  }

  .preview-item img { width: 100%; height: 100%; object-fit: cover; }

  .remove-btn {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 20px;
    height: 20px;
    background: rgba(0,0,0,0.6);
    border-radius: 50%;
    border: none;
    cursor: pointer;
    color: white;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .file-name {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: rgba(26,31,110,0.8);
    color: white;
    font-size: 9px;
    padding: 3px 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* LANG TOGGLE */
  .lang-toggle {
    display: flex;
    background: var(--mid-grey);
    border-radius: 10px;
    padding: 3px;
    gap: 2px;
    margin-bottom: 20px;
    width: fit-content;
  }

  .lang-btn {
    padding: 7px 18px;
    border: none;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    background: transparent;
    color: var(--text-secondary);
    transition: all 0.2s;
  }

  .lang-btn.active {
    background: white;
    color: var(--brand-blue);
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
  }

  /* TEXT INPUT */
  .input-row { display: flex; gap: 12px; align-items: flex-end; }
  .text-input-wrap { flex: 1; }

  .text-input-wrap label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--brand-blue);
    margin-bottom: 8px;
  }

  textarea {
    width: 100%;
    padding: 14px 16px;
    border: 2px solid var(--mid-grey);
    border-radius: 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    color: var(--brand-blue);
    resize: none;
    outline: none;
    background: white;
    transition: border-color 0.2s;
    line-height: 1.5;
  }

  textarea:focus { border-color: var(--turquoise); }
  textarea::placeholder { color: #b0b6c3; }

  /* SUBMIT */
  .submit-btn {
    padding: 14px 32px;
    background: var(--brand-blue);
    color: white;
    border: none;
    border-radius: 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  .submit-btn:hover:not(:disabled) { background: #13185a; transform: translateY(-1px); }
  .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  /* ERROR */
  .error-banner {
    display: none;
    background: #fee2e2;
    border: 2px solid #fca5a5;
    border-radius: 12px;
    padding: 14px 18px;
    font-size: 14px;
    color: #991b1b;
    margin-top: 16px;
  }

  .error-banner.visible { display: block; }

  /* LOADING */
  .loading-state {
    display: none;
    text-align: center;
    padding: 60px 32px;
    background: white;
    border-radius: 16px;
    margin-top: 32px;
  }

  .loading-state.visible { display: block; }

  .spinner {
    width: 48px;
    height: 48px;
    border: 4px solid var(--mid-grey);
    border-top-color: var(--turquoise);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 20px;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .loading-text { font-size: 16px; font-weight: 600; color: var(--brand-blue); margin-bottom: 6px; }
  .loading-sub { font-size: 13px; color: var(--text-secondary); }

  /* RESULT PANEL */
  .result-panel { display: none; margin-top: 32px; animation: fadeUp 0.4s ease; }
  .result-panel.visible { display: block; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* SCORE CARD */
  .score-card {
    background: var(--brand-blue);
    border-radius: 20px;
    padding: 32px 36px;
    display: flex;
    align-items: center;
    gap: 32px;
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
  }

  .score-circle {
    position: relative;
    width: 90px;
    height: 90px;
    flex-shrink: 0;
  }

  .score-ring { width: 90px; height: 90px; transform: rotate(-90deg); }

  .score-number {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -54%);
    font-size: 26px;
    font-weight: 800;
    color: white;
  }

  .score-pct {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, 14px);
    font-size: 11px;
    color: rgba(255,255,255,0.6);
  }

  .score-info { flex: 1; }

  .score-verdict {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 4px 12px;
    border-radius: 20px;
    margin-bottom: 8px;
  }

  .verdict-pass { background: rgba(16,185,129,0.2); color: #6ee7b7; }
  .verdict-risk { background: rgba(245,158,11,0.2); color: #fcd34d; }
  .verdict-fail { background: rgba(239,68,68,0.2); color: #fca5a5; }

  .score-asset-name { font-size: 20px; font-weight: 700; color: white; margin-bottom: 6px; }
  .score-summary { font-size: 14px; color: rgba(255,255,255,0.75); line-height: 1.5; }

  /* CATEGORIES */
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }

  .cat-card {
    background: white;
    border-radius: 14px;
    padding: 20px;
    border: 1.5px solid var(--mid-grey);
  }

  .cat-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  .cat-name { font-size: 13px; font-weight: 700; color: var(--brand-blue); }
  .cat-score-badge { font-size: 13px; font-weight: 700; }
  .cat-bar-track { height: 6px; background: var(--mid-grey); border-radius: 4px; margin-bottom: 10px; }
  .cat-bar-fill { height: 100%; border-radius: 4px; transition: width 0.6s; }
  .cat-note { font-size: 12px; color: var(--text-secondary); line-height: 1.5; }

  /* FINDINGS */
  .findings-block {
    background: white;
    border-radius: 16px;
    padding: 28px;
    border: 1.5px solid var(--mid-grey);
    margin-bottom: 24px;
  }

  .findings-title { font-size: 15px; font-weight: 700; margin-bottom: 20px; }

  .finding-item {
    display: flex;
    gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid var(--mid-grey);
  }

  .finding-item:last-child { border-bottom: none; padding-bottom: 0; }

  .finding-dot {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .dot-red { background: #fef2f2; color: #ef4444; }
  .dot-amber { background: #fffbeb; color: #f59e0b; }
  .dot-green { background: #f0fdf4; color: #10b981; }

  .finding-content { flex: 1; }
  .finding-label { font-size: 11px; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 4px; }
  .label-red { color: #ef4444; }
  .label-amber { color: #f59e0b; }
  .label-green { color: #10b981; }
  .finding-title-text { font-size: 14px; font-weight: 600; color: var(--brand-blue); margin-bottom: 4px; }
  .finding-body { font-size: 13px; color: var(--text-secondary); line-height: 1.5; margin-bottom: 6px; }

  .finding-fix {
    font-size: 12px;
    color: var(--brand-blue);
    background: #f5f6fa;
    padding: 8px 12px;
    border-radius: 8px;
    line-height: 1.5;
    border-left: 3px solid var(--turquoise);
  }

  .new-review-btn {
    display: block;
    width: 100%;
    padding: 14px;
    background: white;
    color: var(--brand-blue);
    border: 2px solid var(--mid-grey);
    border-radius: 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
  }

  .new-review-btn:hover { border-color: var(--turquoise); color: var(--turquoise); }

  footer { text-align: center; padding: 32px; font-size: 12px; color: var(--text-secondary); }

  @media (max-width: 600px) {
    header { padding: 0 20px; }
    .main { padding: 32px 16px 60px; }
    .page-heading { font-size: 28px; }
    .score-card { flex-direction: column; text-align: center; }
    .input-row { flex-direction: column; }
    .submit-btn { width: 100%; justify-content: center; }
  }
</style>
</head>
<body>

<header>
  <div class="logo-wrap">
    <img src="data:image/png;base64," style="height:52px;width:auto;" />
  </div>
  <span class="badge">Internal Tool</span>
</header>
<div class="gradient-bar"></div>

<div class="main">
  <p class="page-title">Brand Review</p>
  <h1 class="page-heading">Is your asset on brand?</h1>
  <p class="page-sub">Upload an image or paste copy below. Our brand guardian will review it against Stepstone's guidelines and give you a score.</p>

  <div class="lang-toggle">
    <button class="lang-btn active" onclick="setLang('en', this)">English</button>
    <button class="lang-btn" onclick="setLang('de', this)">Deutsch</button>
  </div>

  <div class="upload-zone" id="uploadZone">
    <input type="file" id="fileInput" accept="image/*" multiple onchange="handleFiles(this.files)">
    <div class="upload-icon">
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" width="48" height="48">
        <defs>
          <linearGradient id="ugGrad" x1="0" y1="0" x2="48" y2="48" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#FF9E8C"/>
            <stop offset="50%" stop-color="#c8e8e8"/>
            <stop offset="100%" stop-color="#29D3DF"/>
          </linearGradient>
        </defs>
        <rect width="48" height="48" rx="10" fill="url(#ugGrad)"/>
        <path d="M24 30V17M24 17L16 25M24 17L32 25" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        <line x1="15" y1="35" x2="33" y2="35" stroke="white" stroke-width="3" stroke-linecap="round"/>
      </svg>
    </div>
    <p class="upload-title">Drop your asset here</p>
    <p class="upload-hint">PNG, JPG or GIF &middot; <strong>Click to browse</strong></p>
  </div>

  <div class="preview-strip" id="previewStrip"></div>

  <div class="input-row">
    <div class="text-input-wrap">
      <label for="copyInput">Or paste copy / describe the asset</label>
      <textarea id="copyInput" rows="3" placeholder="e.g. 'Besser als jede Black Week &ndash; mit Stepstone All Jobs Starter'"></textarea>
    </div>
    <button class="submit-btn" id="submitBtn" onclick="runReview()" disabled>
      <svg style="width:18px;height:18px;stroke:white;fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      Review
    </button>
  </div>

  <div class="error-banner" id="errorBanner"></div>

  <div class="loading-state" id="loadingState">
    <div class="spinner"></div>
    <p class="loading-text">Reviewing against brand guidelines&hellip;</p>
    <p class="loading-sub">Checking colour, typography, tone of voice, logo &amp; layout</p>
  </div>

  <div class="result-panel" id="resultPanel"></div>
</div>

<footer>Stepstone Brand Guardian &middot; Internal use only &middot; Powered by Claude</footer>

<script>
  let uploadedFiles = [];
  let currentLang = 'en';

  function setLang(lang, btn) {
    currentLang = lang;
    document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  }

  function handleFiles(files) {
    Array.from(files).forEach(file => {
      if (!file.type.startsWith('image/')) return;
      uploadedFiles.push(file);
      renderPreview(file);
    });
    checkReady();
  }

  function renderPreview(file) {
    const strip = document.getElementById('previewStrip');
    const reader = new FileReader();
    reader.onload = function(e) {
      const div = document.createElement('div');
      div.className = 'preview-item';
      const img = document.createElement('img');
      img.src = e.target.result;
      const btn = document.createElement('button');
      btn.className = 'remove-btn';
      btn.innerHTML = '&times;';
      btn.onclick = function() { removeFile(file.name, btn); };
      const label = document.createElement('div');
      label.className = 'file-name';
      label.textContent = file.name;
      div.appendChild(img);
      div.appendChild(btn);
      div.appendChild(label);
      strip.appendChild(div);
    };
    reader.readAsDataURL(file);
  }

  function removeFile(name, btn) {
    uploadedFiles = uploadedFiles.filter(function(f) { return f.name !== name; });
    btn.closest('.preview-item').remove();
    checkReady();
  }

  function checkReady() {
    const hasFile = uploadedFiles.length > 0;
    const hasText = document.getElementById('copyInput').value.trim().length > 0;
    document.getElementById('submitBtn').disabled = !(hasFile || hasText);
  }

  document.getElementById('copyInput').addEventListener('input', checkReady);

  const zone = document.getElementById('uploadZone');
  zone.addEventListener('dragover', function(e) { e.preventDefault(); zone.classList.add('dragover'); });
  zone.addEventListener('dragleave', function() { zone.classList.remove('dragover'); });
  zone.addEventListener('drop', function(e) {
    e.preventDefault();
    zone.classList.remove('dragover');
    handleFiles(e.dataTransfer.files);
  });

  function fileToBase64(file) {
    return new Promise(function(res, rej) {
      const r = new FileReader();
      r.onload = function() { res(r.result.split(',')[1]); };
      r.onerror = rej;
      r.readAsDataURL(file);
    });
  }

  // Compress images through canvas, with FileReader fallback for tricky formats
  function compressAndEncode(file) {
    return new Promise(function(res, rej) {
      const MAX_B64_CHARS = 5000000; // ~3.75MB decoded — safely under 5MB API limit

      function compressImage(img) {
        let maxDim;
        if (file.size > 8 * 1024 * 1024)       maxDim = 1200;
        else if (file.size > 5 * 1024 * 1024)  maxDim = 1400;
        else if (file.size > 3 * 1024 * 1024)  maxDim = 1600;
        else                                    maxDim = 1920;

        function renderAndEncode(dim, quality) {
          try {
            const canvas = document.createElement('canvas');
            let w = img.naturalWidth || img.width;
            let h = img.naturalHeight || img.height;

            if (!w || !h) { rej(new Error('Image has zero dimensions')); return; }

            if (w > dim || h > dim) {
              const ratio = Math.min(dim / w, dim / h);
              w = Math.round(w * ratio);
              h = Math.round(h * ratio);
            }

            canvas.width = w;
            canvas.height = h;
            const ctx = canvas.getContext('2d');
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(0, 0, w, h); // white bg for transparent PNGs
            ctx.drawImage(img, 0, 0, w, h);

            const dataUrl = canvas.toDataURL('image/jpeg', quality);
            if (!dataUrl || dataUrl === 'data:,') { rej(new Error('Canvas toDataURL returned empty')); return; }

            const b64 = dataUrl.split(',')[1];
            if (!b64) { rej(new Error('No base64 data after split')); return; }

            if (b64.length <= MAX_B64_CHARS) {
              res(b64);
            } else if (quality > 0.4) {
              renderAndEncode(dim, Math.round((quality - 0.1) * 10) / 10);
            } else if (dim > 600) {
              renderAndEncode(Math.round(dim * 0.75), 0.85);
            } else {
              res(b64); // last resort
            }
          } catch(e) {
            rej(new Error('Canvas render failed: ' + e.message));
          }
        }

        renderAndEncode(maxDim, 0.88);
      }

      // Try objectURL first
      function tryObjectUrl() {
        const img = new Image();
        const objectUrl = URL.createObjectURL(file);
        img.onload = function() {
          URL.revokeObjectURL(objectUrl);
          compressImage(img);
        };
        img.onerror = function() {
          URL.revokeObjectURL(objectUrl);
          // Fallback: try FileReader instead
          tryFileReader();
        };
        img.src = objectUrl;
      }

      // FileReader fallback for formats that don't work with objectURL
      function tryFileReader() {
        const reader = new FileReader();
        reader.onload = function(e) {
          const img = new Image();
          img.onload = function() { compressImage(img); };
          img.onerror = function() {
            // Both methods failed — if file is small enough just send raw
            if (file.size < 4.5 * 1024 * 1024) {
              const b64 = e.target.result.split(',')[1];
              if (b64) { res(b64); } else { rej(new Error('Could not read image data')); }
            } else {
              rej(new Error('Image format not supported for compression and file is too large to send raw'));
            }
          };
          img.src = e.target.result;
        };
        reader.onerror = function() { rej(new Error('FileReader failed to read the file')); };
        reader.readAsDataURL(file);
      }

      tryObjectUrl();
    });
  }

  async function runReview() {
    const copyText = document.getElementById('copyInput').value.trim();
    const errorBanner = document.getElementById('errorBanner');
    errorBanner.classList.remove('visible');
    document.getElementById('loadingState').classList.add('visible');
    document.getElementById('resultPanel').classList.remove('visible');
    document.getElementById('submitBtn').disabled = true;

    const langNote = currentLang === 'de'
      ? 'Apply German Tone of Voice guidelines specifically.'
      : 'Apply English Tone of Voice guidelines.';

    const systemPrompt = 'You are the Stepstone Brand Guardian. You review creative assets — images, copy, or both — against Stepstone\'s brand guidelines and provide a structured, scored assessment.\n\nBRAND GUIDELINES:\n\n== BRAND FOUNDATION ==\n- Vision: "The right job for everyone"\n- Mission: We help companies hire the right talent\n- B2C Positioning: Simply find the right job\n- B2B Positioning: Simply find the right talent – for all jobs\n- Brand Archetype: Hero + Explorer + sprinkle of Jester\n- Brand Persona: "The Wingman" — witty, confident, always by your side\n\n== COLOUR SYSTEM ==\n- Primary palette: Brand Blue (#1a1f6e), Coral (#f07060), Turquoise (#40c8c8), White\n- Hero gradient: Coral → Turquoise (the signature brand asset)\n- NEVER use black or near-black backgrounds\n- NEVER use off-palette colours\n\n== TYPOGRAPHY ==\n- Font: Relative Pro only (Book, Medium, Bold, Black weights)\n- Headlines: Black weight\n- Body: Medium weight\n- ALWAYS mixed case. NEVER all-caps. NEVER italics\n\n== LOGO ==\n- Must appear on ALL brand communications\n- Stoney mark + wordmark combination\n- Strict clear space and minimum size rules apply\n- The following 5 brands share the same brand design system and guidelines. Treat their logos as equivalent — the presence of ANY of these logos satisfies the logo requirement:\n  1. Stepstone\n  2. NIJobs\n  3. Totaljobs\n  4. Irishjobs\n  5. Pnet\n- Do NOT flag an asset as missing a logo if any one of these five brand logos is present\n\n== IMAGERY ==\n- Real, authentic, atmospheric people photography\n- NO heavy filters, duotones, or stylised overlays\n- Illustrations: brand palette only, optimistic style\n\n== TONE OF VOICE (ENGLISH) ==\nVoice Pillars:\n1. AMBITIOUS (We\'re go-getters): Active voice, direct, adds momentum. Every word empowers.\n2. HONEST (We\'re straight up): Stick to facts. Direct, not cold. Simple, not boring. Cut through with confidence.\n3. ENTHUSIASTIC (We\'re witty optimists): Spot the opportunity. Inspire people onwards and upwards.\n\nWe are NOT:\n- Brutal: Never cruel. "You are the reason you lost your job" is forbidden.\n- Hippy: Not dreamy or abstract. "Today is a gift. Carpe Diem" is forbidden.\n- Arrogant: Confident but put companions first. "There\'s us. And there\'s the unemployment line" is forbidden.\n\nStyle:\n- Say "Find" not "Search"\n- Say "Job" not "Employment Opportunity"\n- Say "Learn" not "Upskill"\n- Say "Clear" not "Transparent"\n- Say "Improve" not "Optimise"\n- Say "Plan" not "Resource Allocation"\n- Say "Job Ads" not "Listings"\n- No business jargon. Plain, inclusive language always.\n\nHeadlines:\n- 5–10 words ideal. 3–5 for punchy. 7–10 for context.\n- Mixed case only. Capitalise proper nouns only. NO title case. NO all-caps.\n\nLonger copy:\n- Short sentences that get to the point. Variation brings personality.\n- Break up text with line breaks and bullet points. No walls of text.\n\nB2B tone: More functional, direct, polite, witty. Used for: sales emails, webinar promos, LinkedIn campaigns.\nB2C tone: More expressive, simple, casual, witty. Used for: organic social, OOH, emails to jobseekers.\n\nCTAs:\n- ALL conversion assets MUST have a clear, strong CTA\n- Awareness: implied solution. Consideration: clear message + CTA. Conversion: direct + strong CTA.\n\nLinkedIn ad character limits:\n- Intro text: max 150 characters\n- Headline text: max 70 characters\n\n== TONE OF VOICE (GERMAN) ==\nVoice Pillars:\n1. AMBITIONIERT (Echte Macher): Aktiver Sprachstil, klar, direkt, voller Energie.\n2. EHRLICH (Immer geradeaus): Klar schreiben, direkt sprechen. Transparent, nicht kryptisch.\n3. ENTHUSIASTISCH (Spritzige Optimisten): Immer eine Chance sehen. Menschlich, lösungsorientiert.\n\nWir sind NICHT:\n- Gemein: Niemals verletzend. "Du bist der Grund, warum du deinen Job verloren hast" ist verboten.\n- Weltfremd: Nicht träumerisch. "Heute ist ein Geschenk. Carpe Diem" ist verboten.\n- Arrogant: "Hier sind wir. Und da ist die Schlange vor dem Arbeitsamt" ist verboten.\n\nSprachregeln:\n- IMMER "du" (informal) — außer wenn der Kanal "Sie" erfordert\n- Kein Gendern (neutrale, inklusive Sprache stattdessen)\n- Zahlenformat: 25.000 € (Punkt als Tausender-Trennzeichen, Leerzeichen vor €)\n- Anführungszeichen: „so" (nicht "so")\n- Kein langer, umständlicher Stil\n\nHeadlines (DE):\n- 5–10 Wörter ideal. 3–5 für Knalleffekt. 7–10 für mehr Kontext.\n- Nur Substantive großschreiben (normale deutsche Rechtschreibung). KEIN Titel-Case. KEINE Versalien.\n\nCTAs (DE):\n- Awareness: klar, einfach, Lösung angedeutet\n- Consideration: klare Botschaft + starker CTA\n- Conversion: direkte Ansage + klickbarer CTA\n\n== SCORING INSTRUCTIONS ==\\nScore each asset out of 100. ALWAYS return ALL SIX of the following categories in the categories array. If an element is not visible/applicable, score it 0 and explain why.\\n1. Tone of Voice & Copy — language, style, jargon, word choices, headline length, B2B vs B2C tone\\n2. Logo Usage — correct logo present (any of: Stepstone, NIJobs, Totaljobs, Irishjobs, Pnet), correct placement and size\\n3. Colour — on-palette colours only, correct gradient usage, no black/near-black backgrounds\\n4. Typography — Relative Pro font, correct weights, mixed case only, no all-caps, no italics\\n5. Imagery — authentic photography, no heavy filters or duotones, illustrations on-palette only\\n6. CTA & Messaging — clear CTA present, correct funnel stage tone (Awareness/Consideration/Conversion), brand persona alignment\\n\\nVerdict thresholds:\n- 70–100: PASS\n- 50–69: AT RISK\n- 0–49: FAIL\n\nReturn your response as a JSON object with EXACTLY this structure:\n{\n  "assetName": "string",\n  "overallScore": number,\n  "verdict": "PASS" | "AT RISK" | "FAIL",\n  "summary": "2-3 sentence overview",\n  "categories": [\n    { "name": "string", "score": number, "comment": "string (2-3 sentence assessment)" }\n  ],\n  "findings": [\n    { "type": "violation" | "warning" | "pass", "category": "string (e.g. Tone of Voice, Logo, Colour, Typography, Imagery, CTA)", "title": "string (short finding summary)", "description": "string (detailed explanation)", "fix": "string (suggested fix — omit if type is pass)" }\n  ]\n}';

    try {
      const userContent = [];

      for (let i = 0; i < uploadedFiles.length; i++) {
        const file = uploadedFiles[i];
        let b64;
        try {
          b64 = await compressAndEncode(file);
        } catch (compressErr) {
          throw new Error('Could not process image "' + file.name + '": ' + (compressErr.message || 'compression failed'));
        }
        if (!b64 || b64.length === 0) {
          throw new Error('Image "' + file.name + '" produced empty output after compression.');
        }
        userContent.push({
          type: 'image',
          source: { type: 'base64', media_type: 'image/jpeg', data: b64 }
        });
      }

      if (copyText) {
        userContent.push({ type: 'text', text: 'Asset copy / description:\n' + copyText });
      }

      if (userContent.length === 0) {
        throw new Error('No content to review.');
      }

      userContent.push({ type: 'text', text: 'Please review this asset against all Stepstone brand guidelines and return your analysis as JSON.' });

      let response;
      try {
        response = await fetch('https://api.anthropic.com/v1/messages', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            model: 'claude-sonnet-4-20250514',
            max_tokens: 4000,
            system: systemPrompt,
            messages: [{ role: 'user', content: userContent }]
          })
        });
      } catch (fetchErr) {
        throw new Error('Network error — check your internet connection and try again. (' + (fetchErr.message || 'fetch failed') + ')');
      }

      let data;
      try {
        data = await response.json();
      } catch (jsonErr) {
        throw new Error('Server returned an unreadable response (HTTP ' + response.status + ')');
      }

      if (!response.ok || data.error) {
        const msg = (data.error && data.error.message) ? data.error.message : 'HTTP ' + response.status;
        throw new Error('API error: ' + msg);
      }

      if (!data.content || data.content.length === 0) {
        throw new Error('API returned an empty response. Please try again.');
      }

      const rawText = data.content.map(function(b) { return b.text || ''; }).join('');
      const clean = rawText.replace(/```json|```/g, '').trim();
      const s = clean.indexOf('{');
      const e2 = clean.lastIndexOf('}');
      if (s === -1 || e2 === -1) throw new Error('Could not parse response. Raw: ' + clean.slice(0, 200));

      let parsed;
      try {
        parsed = JSON.parse(clean.slice(s, e2 + 1));
      } catch (parseErr) {
        throw new Error('JSON parse failed: ' + parseErr.message + '. Raw: ' + clean.slice(s, s + 200));
      }

      renderResults(parsed);

    } catch (err) {
      document.getElementById('loadingState').classList.remove('visible');
      const msg = (err && err.message) ? err.message : JSON.stringify(err) || 'Unknown error';
      errorBanner.textContent = 'Something went wrong: ' + msg;
      errorBanner.classList.add('visible');
      document.getElementById('submitBtn').disabled = false;
    }
  }

  function barColour(s) { return s >= 70 ? '#10b981' : s >= 50 ? '#f59e0b' : '#ef4444'; }
  function verdictClass(v) { return v === 'PASS' ? 'verdict-pass' : v === 'AT RISK' ? 'verdict-risk' : 'verdict-fail'; }
  function dotClass(t) { return t === 'violation' ? 'dot-red' : t === 'warning' ? 'dot-amber' : 'dot-green'; }
  function labelClass(t) { return t === 'violation' ? 'label-red' : t === 'warning' ? 'label-amber' : 'label-green'; }
  function findingLabel(t) { return t === 'violation' ? 'Violation' : t === 'warning' ? 'Recommendation' : 'Pass'; }

  function renderResults(r) {
    document.getElementById('loadingState').classList.remove('visible');
    const circ = 2 * Math.PI * 38;
    const dash = (r.overallScore / 100) * circ;
    const sc = barColour(r.overallScore);

    let catsHTML = '';
    r.categories.filter(function(c) { return c.comment !== 'N/A' && c.comment !== 'n/a'; }).forEach(function(c) {
      catsHTML += '<div class="cat-card">' +
        '<div class="cat-header"><span class="cat-name">' + c.name + '</span><span class="cat-score-badge" style="color:' + barColour(c.score) + '">' + c.score + '%</span></div>' +
        '<div class="cat-bar-track"><div class="cat-bar-fill" style="width:' + c.score + '%;background:' + barColour(c.score) + '"></div></div>' +
        '<p class="cat-note">' + c.comment + '</p>' +
        '</div>';
    });

    let findHTML = '';
    r.findings.forEach(function(f) {
      findHTML += '<div class="finding-item">' +
        '<div class="finding-dot ' + dotClass(f.type) + '">' + (f.type === 'violation' ? '!' : f.type === 'warning' ? '~' : 'v') + '</div>' +
        '<div class="finding-content">' +
        '<p class="finding-label ' + labelClass(f.type) + '">' + findingLabel(f.type) + ' &middot; ' + f.category + '</p>' +
        '<p class="finding-title-text">' + f.title + '</p>' +
        '<p class="finding-body">' + f.description + '</p>' +
        (f.fix ? '<div class="finding-fix"><strong>Fix:</strong> ' + f.fix + '</div>' : '') +
        '</div></div>';
    });

    document.getElementById('resultPanel').innerHTML =
      '<div class="score-card">' +
        '<div class="score-circle">' +
          '<svg class="score-ring" viewBox="0 0 90 90">' +
            '<circle cx="45" cy="45" r="38" fill="none" stroke="rgba(255,255,255,.1)" stroke-width="6"/>' +
            '<circle cx="45" cy="45" r="38" fill="none" stroke="' + sc + '" stroke-width="6" stroke-dasharray="' + dash + ' ' + circ + '" stroke-dashoffset="' + (circ * 0.25) + '" stroke-linecap="round"/>' +
          '</svg>' +
          '<span class="score-number">' + r.overallScore + '</span>' +
          '<span class="score-pct">/ 100</span>' +
        '</div>' +
        '<div class="score-info">' +
          '<div class="score-verdict ' + verdictClass(r.verdict) + '">' + r.verdict + '</div>' +
          '<p class="score-asset-name">' + r.assetName + '</p>' +
          '<p class="score-summary">' + r.summary + '</p>' +
        '</div>' +
      '</div>' +
      '<div class="categories-grid">' + catsHTML + '</div>' +
      '<div class="findings-block">' +
        '<p class="findings-title">Detailed Findings (' + r.findings.length + ')</p>' +
        findHTML +
      '</div>' +
      '<button class="new-review-btn" onclick="resetTool()">&#8592; Review another asset</button>';

    document.getElementById('resultPanel').classList.add('visible');
    document.getElementById('resultPanel').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function resetTool() {
    uploadedFiles = [];
    document.getElementById('previewStrip').innerHTML = '';
    document.getElementById('copyInput').value = '';
    document.getElementById('resultPanel').classList.remove('visible');
    document.getElementById('errorBanner').classList.remove('visible');
    document.getElementById('submitBtn').disabled = true;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>
</body>
</html>
